# Heat Project File for Lemonade Nexus VPN
# Generates WiX fragment from build output
#
# Usage:
#   heat.exe dir "path\to\build" -o BuildFiles.wxs -gg -sfrag -srd -cg ApplicationFiles -dr APPLICATIONFOLDER -var var.BuildDir

<?xml version="1.0" encoding="utf-8"?>
<!--
  This is a template for the WiX fragment generated by Heat.exe
  The actual file will be generated during the build process
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Fragment>
    <ComponentGroup Id="ApplicationFiles" Directory="APPLICATIONFOLDER">
      <!--
        Heat.exe will populate this with all files from the build directory.
        Run: heat.exe dir "..\..\..\build\windows\runner\Release"
                  -o BuildFiles.wxs
                  -gg
                  -sfrag
                  -srd
                  -cg ApplicationFiles
                  -dr APPLICATIONFOLDER
                  -var var.BuildDir
      -->

      <!-- Main executable -->
      <Component Guid="{B1C2D3E4-F5A6-7890-ABCD-EF1234567891}">
        <File Id="lemonade_nexus.exe"
              Source="$(var.BuildDir)\lemonade_nexus.exe"
              KeyPath="yes"
              Checksum="yes">
          <!-- Shortcut configuration -->
          <Shortcut Id="StartMenuShortcut"
                    Directory="ProgramMenuFolder"
                    Name="Lemonade Nexus VPN"
                    Description="Secure WireGuard Mesh VPN Client" />
        </File>
      </Component>

      <!-- Flutter runtime -->
      <Component Guid="{C2D3E4F5-A6B7-8901-CDEF-123456789012}">
        <File Id="flutter_windows.dll"
              Source="$(var.BuildDir)\flutter_windows.dll"
              KeyPath="yes" />
      </Component>

      <Component Guid="{D3E4F5A6-B7C8-9012-EFAB-234567890123}">
        <File Id="icudtl.dat"
              Source="$(var.BuildDir)\icudtl.dat"
              KeyPath="yes" />
      </Component>

      <!-- Flutter data -->
      <Component Guid="{E4F5A6B7-C8D9-0123-FABC-345678901234}">
        <File Id="app.so"
              Source="$(var.BuildDir)\data\app.so"
              KeyPath="yes" />
      </Component>

      <!-- Additional DLLs -->
      <Component Guid="{F5A6B7C8-D9E0-1234-ABCD-456789012345}">
        <File Id="dart_api.dll"
              Source="$(var.BuildDir)\dart_api.dll"
              KeyPath="yes" />
      </Component>

      <Component Guid="{A6B7C8D9-E0F1-2345-BCDE-567890123456}">
        <File Id="flutter_wrapper_app.dll"
              Source="$(var.BuildDir)\flutter_wrapper_app.dll"
              KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <!-- Directory references -->
  <Fragment>
    <DirectoryRef Id="APPLICATIONFOLDER">
      <Directory Id="data" Name="data">
        <Directory Id="flutter_assets" Name="flutter_assets" />
      </Directory>
    </DirectoryRef>
  </Fragment>
</Wix>
